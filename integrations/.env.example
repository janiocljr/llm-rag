# =============================================================================
# backend/.env — RAG system v3 environment configuration
# =============================================================================
# Copy this file to backend/.env and adjust values as needed.
# All variables below can also be set as real environment variables
# (which take precedence over this file).
# =============================================================================

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# When running locally (outside Docker), point to localhost:8200
# When running inside Docker network, Docker Compose sets CHROMA_HOST=chromadb
CHROMA_HOST=localhost
CHROMA_PORT=8200
CHROMA_COLLECTION_EMBEDDINGS=pdf_embeddings
CHROMA_COLLECTION_MEMORY=chat_memory
USE_CHROMA=true

# ── MongoDB ────────────────────────────────────────────────────────────────────
# When running locally (outside Docker):
MONGO_URI=mongodb://ragadmin:ragpassword@localhost:27017/rag_knowledge?authSource=admin
MONGO_DB=rag_knowledge
# Docker Compose root credentials (used by mongo-init.js):
MONGO_ROOT_USER=ragadmin
MONGO_ROOT_PASSWORD=ragpassword

# ── Embedding model ────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=64

# ── Chunking ───────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MIN_CHUNK_TOKENS=20

# ── Retrieval ──────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=8
RETRIEVAL_FINAL_K=3
SIMILARITY_THRESHOLD=0.30
MMR_LAMBDA=0.6
USE_BM25_HYBRID=true
AUTO_CHUNK_TYPE_ROUTING=true
SKIP_TABLE_CHUNKS_IN_INDEX=false

# ── LLM ────────────────────────────────────────────────────────────────────────
LLM_MODEL_PATH=models/mistral-7b-instruct-v0.2.Q4_K_M.gguf
LLM_CONTEXT_LENGTH=4096
LLM_MAX_NEW_TOKENS=512
LLM_TEMPERATURE=0.1
LLM_N_THREADS=8
LLM_N_GPU_LAYERS=0             # set to -1 to use all GPU layers (requires CUDA/Metal)
